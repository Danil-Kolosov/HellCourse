@page
@model buildingCompany.Pages.WorkTypes.IndexModel
@{
    ViewData["Title"] = "Виды работ";
}

<h2>Виды работ</h2>

@if (TempData["Success"] != null)
{
        <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
}

@if (TempData["Error"] != null)
{
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
}

<a asp-page="Index" asp-route-create="true" class="btn btn-primary mb-3">Добавить вид работ</a>

@if (Model.ShowForm)
{
        <div class="card mb-4">
            <div class="card-header">@(Model.ItemId > 0 ? "Редактирование" : "Новый вид работ")</div>
            <div class="card-body">
            @if (Model.ItemId > 0)
            {
                        <!-- Форма для обновления -->
                        <form method="post" asp-page-handler="Update">
                            <input type="hidden" asp-for="ItemId" />

                            <div class="mb-3">
                                <label asp-for="Title" class="form-label">Название работы</label>
                                <input asp-for="Title" class="form-control" required />
                            </div>

                            <div class="mb-3">
                                <label asp-for="PricePerHour" class="form-label">Цена за час (руб.)</label>
                                <input asp-for="PricePerHour" type="number" step="0.01" class="form-control" required />
                            </div>

                            <button type="submit" class="btn btn-success">Сохранить</button>
                            <a asp-page="Index" class="btn btn-secondary">Отмена</a>
                        </form>
            }
            else
            {
                        <!-- Форма для создания -->
                        <form method="post" asp-page-handler="Create">
                            <div class="mb-3">
                                <label asp-for="Title" class="form-label">Название работы</label>
                                <input asp-for="Title" class="form-control" required />
                            </div>

                            <div class="mb-3">
                                <label asp-for="PricePerHour" class="form-label">Цена за час (руб.)</label>
                                <input asp-for="PricePerHour" type="number" step="0.01" class="form-control" required />
                            </div>

                            <button type="submit" class="btn btn-success">Сохранить</button>
                            <a asp-page="Index" class="btn btn-secondary">Отмена</a>
                        </form>
            }
            </div>
        </div>
}

<table class="table table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>Название</th>
            <th>Цена за час</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Items != null && Model.Items.Any())
        {
            @foreach (var item in Model.Items)
            {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.Title</td>
                            <td>@item.PricePerHour.ToString("N2") руб.</td>
                            <td>
                                <a asp-page="Index" asp-route-editId="@item.Id" class="btn btn-sm btn-warning">Изменить</a>
                                <form method="post" asp-page-handler="Delete" style="display: inline;" onsubmit="return confirm('Удалить вид работ @item.Title?')">
                                    <input type="hidden" name="DeleteId" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger">Удалить</button>
                                </form>
                            </td>
                        </tr>
            }
        }
        else
        {
                <tr>
                    <td colspan="4" class="text-center text-muted">Нет данных</td>
                </tr>
        }
    </tbody>
</table>