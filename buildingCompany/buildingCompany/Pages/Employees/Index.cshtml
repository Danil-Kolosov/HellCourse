@page
@model buildingCompany.Pages.Employees.IndexModel
@{
    ViewData["Title"] = "Сотрудники";
}

<h2>Сотрудники</h2>

@if (TempData["Success"] != null)
{
        <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
}

@if (TempData["Error"] != null)
{
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
}

@if (!ViewData.ModelState.IsValid && ViewData.ModelState[string.Empty] != null)
{
        <div class="alert alert-danger">
        @Html.ValidationMessage(string.Empty)
        </div>
}

<!-- Кнопка добавления -->
<a asp-page="Index" asp-route-create="true" class="btn btn-primary mb-3">Добавить сотрудника</a>

<!-- Форма добавления/редактирования -->
@if (Model.ShowForm)
{
        <div class="card mb-4">
            <div class="card-header">@(Model.EmployeeId > 0 ? "Редактирование" : "Новый сотрудник")</div>
            <div class="card-body">
            @if (Model.EmployeeId > 0)
            {
                        <!-- Форма для обновления -->
                        <form method="post" asp-page-handler="Update">
                            <input type="hidden" asp-for="EmployeeId" />

                            <div class="mb-3">
                                <label asp-for="FullName" class="form-label">ФИО</label>
                                <input asp-for="FullName" class="form-control" required />
                                <span asp-validation-for="FullName" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Position" class="form-label">Должность</label>
                                <input asp-for="Position" class="form-control" required />
                                <span asp-validation-for="Position" class="text-danger"></span>
                            </div>

                            <button type="submit" class="btn btn-success">Сохранить</button>
                            <a asp-page="Index" class="btn btn-secondary">Отмена</a>
                        </form>
            }
            else
            {
                        <!-- Форма для создания -->
                        <form method="post" asp-page-handler="Create">
                            <div class="mb-3">
                                <label asp-for="FullName" class="form-label">ФИО</label>
                                <input asp-for="FullName" class="form-control" required />
                                <span asp-validation-for="FullName" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Position" class="form-label">Должность</label>
                                <input asp-for="Position" class="form-control" required />
                                <span asp-validation-for="Position" class="text-danger"></span>
                            </div>

                            <button type="submit" class="btn btn-success">Сохранить</button>
                            <a asp-page="Index" class="btn btn-secondary">Отмена</a>
                        </form>
            }
            </div>
        </div>
}

<!-- Таблица сотрудников -->
<table class="table table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>ФИО</th>
            <th>Должность</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Employees != null && Model.Employees.Any())
        {
            @foreach (var emp in Model.Employees)
            {
                        <tr>
                            <td>@emp.Id</td>
                            <td>@emp.FullName</td>
                            <td>@emp.Position</td>
                            <td>
                                <a asp-page="Index" asp-route-editId="@emp.Id" class="btn btn-sm btn-warning">Изменить</a>
                                <form method="post" asp-page-handler="Delete" style="display: inline;" onsubmit="return confirm('Удалить сотрудника @emp.FullName?')">
                                    <input type="hidden" name="DeleteId" value="@emp.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger">Удалить</button>
                                </form>
                            </td>
                        </tr>
            }
        }
        else
        {
                <tr>
                    <td colspan="4" class="text-center text-muted">Нет данных</td>
                </tr>
        }
    </tbody>
</table>

