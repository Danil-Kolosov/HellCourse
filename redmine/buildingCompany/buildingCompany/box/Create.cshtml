@* @page *@
@* @model buildingCompany.Pages.BuildingSites.IndexModel *@
@* @{ *@
@*     ViewData["Title"] = "Объекты"; *@
@* } *@

@* <h2>Объекты строительства</h2> *@

@* <a asp-page="Index" asp-route-create="true" class="btn btn-success mb-3"> *@
@*     + Новый объект *@
@* </a> *@

@* @if (Model.ShowForm) *@
@* { *@
@*         <div class="card mb-4"> *@
@*             <div class="card-header bg-primary text-white"> *@
@*                 <h4>@(Model.EditingSite?.Id > 0 ? "Редактирование" : "Новый объект")</h4> *@
@*             </div> *@
@*             <div class="card-body"> *@
@*                 <form method="post"> *@
@*                 @if (Model.EditingSite?.Id > 0) *@
@*                 { *@
@*                             <input type="hidden" name="handler" value="update" /> *@
@*                             <input type="hidden" asp-for="EditingSite.Id" /> *@
@*                 } *@
@*                 else *@
@*                 { *@
@*                             <input type="hidden" name="handler" value="create" /> *@
@*                 } *@

@*                     <div class="mb-3"> *@
@*                         <label asp-for="EditingSite.Name" class="form-label">Название</label> *@
@*                         <input asp-for="EditingSite.Name" class="form-control" required /> *@
@*                     </div> *@

@*                     <div class="mb-3"> *@
@*                         <label asp-for="EditingSite.Address" class="form-label">Адрес</label> *@
@*                         <input asp-for="EditingSite.Address" class="form-control" required /> *@
@*                     </div> *@

@*                     <button type="submit" class="btn btn-primary"> *@
@*                     @(Model.EditingSite?.Id > 0 ? "Сохранить" : "Создать") *@
@*                     </button> *@
@*                     <a asp-page="Index" class="btn btn-secondary">Отмена</a> *@
@*                 </form> *@
@*             </div> *@
@*         </div> *@
@* } *@

@* <table class="table"> *@
@*     <thead> *@
@*         <tr> *@
@*             <th>Название</th> *@
@*             <th>Адрес</th> *@
@*             <th>Действия</th> *@
@*         </tr> *@
@*     </thead> *@
@*     <tbody> *@
@*         @foreach (var item in Model.BuildingSites) *@
@*         { *@
@*                 <tr> *@
@*                     <td>@item.Name</td> *@
@*                     <td>@item.Address</td> *@
@*                     <td> *@
@*                         <a asp-page="Index" asp-route-editId="@item.Id" class="btn btn-sm btn-warning"> *@
@*                             Изменить *@
@*                         </a> *@
@*                         <a asp-page="Index" asp-route-deleteId="@item.Id"  *@
